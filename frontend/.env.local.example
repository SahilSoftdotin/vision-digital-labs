# Frontend environment variables
# Copy to .env.local and fill in as needed.

# Leave empty to use the built-in Next.js mock API (/api/v1).
# Set to the Spring Boot backend base URL to switch over with no code changes,
# e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Shared secret for on-demand ISR revalidation. Must match the backend's
# app.revalidate.secret (REVALIDATE_SECRET). The backend calls /api/revalidate
# after content edits to refresh the affected static pages.
REVALIDATE_SECRET=
