# Backend environment variables — copy to .env and fill in.
# These map directly to Spring properties via relaxed binding.

# --- Database (managed Postgres, e.g. Neon/Supabase) ---
# Neon example: jdbc:postgresql://ep-xxx-123.us-east-2.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/visiondigitallab
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# create | update | validate | none  (use 'update' for managed DBs in dev)
JPA_DDL_AUTO=update

# --- Security ---
# Use a long random string (>= 32 chars) in production.
JWT_SECRET=change-me-in-prod-this-is-a-dev-only-secret-key-0123456789
JWT_EXPIRATION_MS=86400000

# --- CORS (frontend origins, comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Seed data + default admin (first run only) ---
SEED_ENABLED=true
ADMIN_EMAIL=admin@visiondigitallab.com
ADMIN_PASSWORD=admin12345

# --- Caching (simple = in-memory; redis later) ---
CACHE_TYPE=simple

# --- Email notifications for new leads (Gmail SMTP) ---
# Use a Google "App Password" (Account > Security > App passwords), NOT your
# normal password. Requires 2-Step Verification enabled.
NOTIFY_ENABLED=false
NOTIFY_TO=                       # where to send lead alerts (your inbox)
NOTIFY_FROM=                     # usually the same as MAIL_USERNAME
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=                   # your Gmail address
MAIL_PASSWORD=                   # the 16-char app password

# --- Server ---
SERVER_PORT=8080

# --- Future: OpenAI for the chat provider ---
OPENAI_API_KEY=
