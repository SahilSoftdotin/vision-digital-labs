# Root monorepo ignores (frontend/.gitignore covers app-specific paths)

# Dependencies
**/node_modules/

# Build output
**/.next/
**/out/
**/build/
**/dist/

# Env files (keep *.example)
**/.env
**/.env.*
!**/.env*.example

# Logs & runtime artifacts
*.log
**/.server.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Misc
*.tsbuildinfo
.vercel
